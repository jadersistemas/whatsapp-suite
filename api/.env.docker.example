GO_VERSION=1.26

APP_NAME=whatsapp-go-api
APP_VERSION=dev
APP_DESCRIPTION=API HTTP em Go para gerenciar instancias do WhatsApp com Whatsmeow
APP_DEVELOPER=CodeChat
APP_REPOSITORY=
BUILD_DATE=
VCS_REF=
VCS_URL=

DOCKER_IMAGE=codechatbr/whatsapp-go-api
IMAGE_TAG=latest

SERVER_PORT=8084
LOG_LEVEL=info
TZ=America/Sao_Paulo
DOCKER_ENV=true

FFMPEG_PATH=/usr/bin/ffmpeg
FFPROBE_PATH=/usr/bin/ffprobe
TMPDIR=/app/tmp

DATABASE_URL=postgres://postgres:change-me@postgres:5432/whatsapp?sslmode=disable
DATABASE_SAVE_DATA_NEW_MESSAGE=true
DATABASE_SAVE_MESSAGE_UPDATE=false
DATABASE_SAVE_DATA_CONTACTS=false

WHATSAPP_SESSION_STORE=postgres
WHATSAPP_SESSION_SQLITE_DSN=file:./data/whatsmeow.db?_foreign_keys=on
WHATSAPP_SESSION_POSTGRES_URL=

WEBHOOK_GLOBAL_URL=
WEBHOOK_GLOBAL_ENABLED=false

AUTHENTICATION_JWT_EXPIRES_IN=3600
AUTHENTICATION_JWT_SECRET=change-me-jwt-secret
AUTHENTICATION_GLOBAL_AUTH_TOKEN=change-me-global-token

QRCODE_LIMIT=5
QRCODE_EXPIRATION_TIME=30
QRCODE_LIGHT_COLOR="#ffffff"
QRCODE_DARK_COLOR="#198754"

CONFIG_SESSION_PHONE_CLIENT=DESKTOP
CONFIG_SESSION_PHONE_NAME=CodeChat

WHATSAPP_PAIRING_TIMEOUT=3m
WHATSAPP_AUTO_RECONNECT=true
WHATSAPP_STARTUP_RECONNECT_CONCURRENCY=5
WHATSAPP_CONNECT_TIMEOUT=30
WHATSAPP_RECONNECT_INITIAL_DELAY=2
WHATSAPP_RECONNECT_MAX_DELAY=60
WHATSAPP_PROFILE_PICTURE_TIMEOUT=15
WHATSAPP_ADDRESS_CACHE_TTL=168h

MESSAGE_PROCESSING_WORKERS=4
MESSAGE_PROCESSING_QUEUE_SIZE=100
MESSAGE_PROCESSING_TIMEOUT=60s
MESSAGE_GROUP_INFO_TIMEOUT=30s
MESSAGE_SEND_TIMEOUT=30s

API_HOST=api.codechat.local
TRAEFIK_NETWORK=traefik_public
TRAEFIK_ENTRYPOINT=websecure
TRAEFIK_TLS=true
TRAEFIK_CERT_RESOLVER=letsencrypt
TRAEFIK_MIDDLEWARES=
TRAEFIK_SERVER_TRANSPORT=
